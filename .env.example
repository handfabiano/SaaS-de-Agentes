# Backend / Edge Functions (NUNCA versione o .env real — só este exemplo)
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Embeddings (RAG). Provedor plugável — a dimensão DEVE bater com vector(N) no schema.
# openai (default): text-embedding-3-small = 1536 dims (não precisa mexer no schema)
# voyage: voyage-3 = 1024 dims (ajuste vector(1024) em knowledge_chunks e match_chunks)
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_DIM=1536            # opcional; força a dimensão de saída
OPENAI_API_KEY=sk-...
# VOYAGE_API_KEY=pa-...
